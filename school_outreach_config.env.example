# School Outreach Agent Config
# Copy this file to school_outreach_config.env and fill in your values.
# Never commit school_outreach_config.env — it is gitignored.

# Google Sheet ID — the long string between /d/ and /edit in your Sheet URL
SCHOOL_OUTREACH_SHEET_ID=your-sheet-id-here

# Gmail address used to send outreach emails (must match your OAuth account)
GMAIL_USER=your@gmail.com
